# Anomaly simulation harness — environment template.
# Copy to .env and edit. NEVER commit a populated .env.

# --- Target (must be a host you own or have explicit auth to test) ---
TARGET_HOST=127.0.0.1

# --- SSH brute-force sim ---
BRUTE_USER=bogususer
BRUTE_PASSWORDS="wrong1 wrong2 wrong3 wrong4 wrong5"

# --- Malware-download sim ---
# Default is the EICAR test file inside a zip — universally treated as a
# benign signature by AV/IDS. Replace with another benign sample if needed.
MALWARE_SAMPLE_URL=https://secure.eicar.org/eicarcom2.zip
MALWARE_SAMPLE_PATH=/tmp/anomaly_sim_sample.zip

# --- Elasticsearch verifier (security is enabled — HTTPS + auth, WS0.1) ---
ES_URL=https://localhost:9200
ES_INDEX=logstash-security-*
ES_USER=elastic
# ES_PASS falls back to ELASTIC_PASSWORD; `source scripts/setup/.env` to populate.
ES_PASS=
# Path to exported ca.crt for strict TLS; leave unset to skip cert verify (local only).
ES_CA=
LOOKBACK_MIN=10

# --- OpenWrt quarantine verifier ---
OPENWRT_HOST=192.168.1.1
OPENWRT_USER=root
SSH_KEY=~/.ssh/id_ed25519_hivemind
